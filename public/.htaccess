# PHP upload limits (for api/orders image uploads)
<IfModule mod_php.c>
  php_value upload_max_filesize 150M
  php_value post_max_size 300M
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Avoid 301 redirect on /api/orders (no slash) so POST body is not lost
  RewriteRule ^api/orders$ api/orders/ [L]

  # Do not rewrite API requests
  RewriteRule ^api/ - [L]

  # Do not rewrite existing files or directories
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # SPA fallback: send all other requests to index.html
  RewriteRule . /index.html [L]
</IfModule>
